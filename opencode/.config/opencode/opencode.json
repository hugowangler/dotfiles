{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "lsp": "allow"
  },
  "mcp": {
    "tickup": {
      "type": "remote",
      "url": "https://mcp.etl.tickup.net/mcp"
    },
    "clickhouse-docs": {
      "type": "remote",
      "url": "https://clickhouse.mcp.kapa.ai/",
      "oauth": {}
    },
    "ask_polars": {
      "type": "remote",
      "url": "https://mcp.pola.rs/mcp"
    },
    "github": {
      "type": "local",
      "command": [
        "docker",
        "run",
        "-i",
        "--rm",
        "-e",
        "GITHUB_PERSONAL_ACCESS_TOKEN",
        "ghcr.io/github/github-mcp-server"
      ],
      "environment": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "{env:GITHUB_TOKEN_MCP}"
      }
    },
    "linear": {
      "type": "remote",
      "url": "https://mcp.linear.app/mcp"
    },
    "tickup-basedoc": {
      "type": "remote",
      "url": "https://tickup-basedoc.tickup-dev.com:9090/sse"
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
      "headers": {
        "CONTEXT7_API_KEY": "ctx7sk-0fd86c83-6cb2-4155-afd5-954d48041579"
      }
    },
      "infra-basedoc": {
        "type": "remote",
        "url": "http://f180-lab-dgx.lab.tickup.net:8091/mcp/sse"
    }
  },
  "lsp": {
    "pyright": {
      "disabled": true
    },
    "ty": {
      "command": [
        "ty",
        "server"
      ],
      "extensions": [
        ".py",
        ".pyi"
      ]
    },
    "ruff": {
      "command": [
        "ruff",
        "server"
      ],
      "extensions": [
        ".py",
        ".pyi"
      ]
    }
  }
}
